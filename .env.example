# JengaTrack — copy to .env and fill in real values (never commit .env)

# Supabase
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (dashboard JWT)
JWT_SECRET=your-32-character-random-string

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini (fallback for intent, OCR, voice)
GEMINI_API_KEY=your_gemini_key_here

# App URL (used in WhatsApp messages and CORS)
DASHBOARD_URL=https://jengatrack.com

# Cron (daily heartbeat)
CRON_SECRET=your-random-cron-secret

# Environment
NODE_ENV=production
