{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/daily-heartbeat", "schedule": "0 17 * * *" }
  ],
  "rewrites": [
    { "source": "/api/daily-heartbeat", "destination": "/api/daily-heartbeat" },
    { "source": "/webhook/webhook", "destination": "/api/whatsapp-webhook" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
